{
  "name": "@yogsoth-ai/biorxiv-mcp",
  "version": "1.0.0",
  "description": "MCP server for bioRxiv/medRxiv preprint full-text retrieval via JATS XML parsing",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "bin": {
    "biorxiv-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "mcp": "tsx src/server.ts",
    "test": "vitest run",
    "build": "tsc",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "biorxiv",
    "medrxiv",
    "preprint",
    "full-text",
    "jats",
    "biology",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yogsoth-ai/biorxiv-mcp.git"
  },
  "author": "yogsoth-ai",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "fast-xml-parser": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
